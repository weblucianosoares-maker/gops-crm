# URL do projeto Supabase
# Encontre em: https://app.supabase.com → Settings → API → Project URL
VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"

# Chave pública (anon key) do Supabase
# Encontre em: https://app.supabase.com → Settings → API → Project API keys → anon (public)
VITE_SUPABASE_ANON_KEY="sb_publishable_SUA_CHAVE_AQUI"
