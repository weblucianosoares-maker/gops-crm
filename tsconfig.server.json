  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "allowImportingTsExtensions": false
  },
  "include": ["server.ts"]
}
